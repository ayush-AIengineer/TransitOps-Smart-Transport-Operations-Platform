<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================== -->
    <!-- MODULE CATEGORY                                                     -->
    <!-- ================================================================== -->
    <record id="module_category_transit" model="ir.module.category">
        <field name="name">TransitOps</field>
        <field name="description">Smart Transport Operations Platform</field>
        <field name="sequence">10</field>
    </record>

    <!-- ================================================================== -->
    <!-- SECURITY GROUPS                                                     -->
    <!-- ================================================================== -->

    <!-- Base User Group (all TransitOps users inherit this) -->
    <record id="group_transit_user" model="res.groups">
        <field name="name">TransitOps User</field>
        <field name="category_id" ref="module_category_transit"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Base access group for all TransitOps users. Grants read access to dashboard.</field>
    </record>

    <!-- Driver / Dispatcher -->
    <record id="group_transit_driver" model="res.groups">
        <field name="name">Driver / Dispatcher</field>
        <field name="category_id" ref="module_category_transit"/>
        <field name="implied_ids" eval="[(4, ref('group_transit_user'))]"/>
        <field name="comment">Creates trips, assigns vehicles and drivers, monitors active deliveries, logs fuel consumption.</field>
    </record>

    <!-- Safety Officer -->
    <record id="group_transit_safety" model="res.groups">
        <field name="name">Safety Officer</field>
        <field name="category_id" ref="module_category_transit"/>
        <field name="implied_ids" eval="[(4, ref('group_transit_user'))]"/>
        <field name="comment">Ensures driver compliance, tracks license validity, monitors safety scores.</field>
    </record>

    <!-- Financial Analyst -->
    <record id="group_transit_finance" model="res.groups">
        <field name="name">Financial Analyst</field>
        <field name="category_id" ref="module_category_transit"/>
        <field name="implied_ids" eval="[(4, ref('group_transit_user'))]"/>
        <field name="comment">Reviews operational expenses, fuel consumption, maintenance costs, and profitability.</field>
    </record>

    <!-- Fleet Manager (Full Access) -->
    <record id="group_transit_manager" model="res.groups">
        <field name="name">Fleet Manager</field>
        <field name="category_id" ref="module_category_transit"/>
        <field name="implied_ids" eval="[(4, ref('group_transit_user'))]"/>
        <field name="comment">Full access to all TransitOps features including vehicle lifecycle, maintenance, dispatch, and reporting.</field>
    </record>

    <!-- ================================================================== -->
    <!-- RECORD RULES                                                        -->
    <!-- ================================================================== -->

    <!-- Fleet Manager: Global access to all records -->
    <record id="rule_vehicle_manager" model="ir.rule">
        <field name="name">Fleet Manager: All Vehicles</field>
        <field name="model_id" ref="model_transit_vehicle"/>
        <field name="groups" eval="[(4, ref('group_transit_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_trip_manager" model="ir.rule">
        <field name="name">Fleet Manager: All Trips</field>
        <field name="model_id" ref="model_transit_trip"/>
        <field name="groups" eval="[(4, ref('group_transit_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_driver_manager" model="ir.rule">
        <field name="name">Fleet Manager: All Drivers</field>
        <field name="model_id" ref="model_transit_driver"/>
        <field name="groups" eval="[(4, ref('group_transit_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_maintenance_manager" model="ir.rule">
        <field name="name">Fleet Manager: All Maintenance</field>
        <field name="model_id" ref="model_transit_maintenance"/>
        <field name="groups" eval="[(4, ref('group_transit_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_fuel_log_manager" model="ir.rule">
        <field name="name">Fleet Manager: All Fuel Logs</field>
        <field name="model_id" ref="model_transit_fuel_log"/>
        <field name="groups" eval="[(4, ref('group_transit_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_expense_manager" model="ir.rule">
        <field name="name">Fleet Manager: All Expenses</field>
        <field name="model_id" ref="model_transit_expense"/>
        <field name="groups" eval="[(4, ref('group_transit_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- All users: Read access to vehicles and drivers -->
    <record id="rule_vehicle_user" model="ir.rule">
        <field name="name">TransitOps User: Read Vehicles</field>
        <field name="model_id" ref="model_transit_vehicle"/>
        <field name="groups" eval="[(4, ref('group_transit_user'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_driver_user" model="ir.rule">
        <field name="name">TransitOps User: Read Drivers</field>
        <field name="model_id" ref="model_transit_driver"/>
        <field name="groups" eval="[(4, ref('group_transit_user'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ================================================================== -->
    <!-- SEQUENCES                                                           -->
    <!-- ================================================================== -->

    <record id="seq_transit_trip" model="ir.sequence">
        <field name="name">Transit Trip Sequence</field>
        <field name="code">transit.trip</field>
        <field name="prefix">TRIP/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_transit_maintenance" model="ir.sequence">
        <field name="name">Transit Maintenance Sequence</field>
        <field name="code">transit.maintenance</field>
        <field name="prefix">MAINT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_transit_fuel_log" model="ir.sequence">
        <field name="name">Transit Fuel Log Sequence</field>
        <field name="code">transit.fuel.log</field>
        <field name="prefix">FUEL/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_transit_expense" model="ir.sequence">
        <field name="name">Transit Expense Sequence</field>
        <field name="code">transit.expense</field>
        <field name="prefix">EXP/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
