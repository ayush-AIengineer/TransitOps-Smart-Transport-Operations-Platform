<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================== -->
    <!-- EMAIL TEMPLATE: License Expiry Warning                              -->
    <!-- ================================================================== -->
    <record id="email_template_license_expiry_warning" model="mail.template">
        <field name="name">TransitOps: License Expiry Warning</field>
        <field name="model_id" ref="model_transit_driver"/>
        <field name="subject">⚠️ License Expiry Warning - {{ object.name }}</field>
        <field name="email_from">{{ (object.env.company.email or 'noreply@transitops.com') }}</field>
        <field name="email_to">{{ object.email or '' }}</field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px; font-size: 14px;">
                <table border="0" cellpadding="0" cellspacing="0" width="100%"
                       style="background-color: #f5f5f5; padding: 20px;">
                    <tr>
                        <td align="center">
                            <table border="0" cellpadding="0" cellspacing="0" width="600"
                                   style="background-color: #ffffff; border-radius: 8px; overflow: hidden;">
                                <!-- Header -->
                                <tr>
                                    <td style="background-color: #ff9800; padding: 20px; text-align: center;">
                                        <h1 style="color: #ffffff; margin: 0;">
                                            ⚠️ License Expiry Warning
                                        </h1>
                                    </td>
                                </tr>
                                <!-- Body -->
                                <tr>
                                    <td style="padding: 30px;">
                                        <p>Dear <strong>{{ object.name }}</strong>,</p>
                                        <p>This is an automated notification from <strong>TransitOps</strong>
                                           to inform you that your driving license is expiring soon.</p>

                                        <table border="0" cellpadding="8" cellspacing="0" width="100%"
                                               style="border: 1px solid #ddd; border-radius: 4px; margin: 20px 0;">
                                            <tr style="background-color: #f9f9f9;">
                                                <td><strong>License Number</strong></td>
                                                <td>{{ object.license_number }}</td>
                                            </tr>
                                            <tr>
                                                <td><strong>License Category</strong></td>
                                                <td>{{ object.license_category }}</td>
                                            </tr>
                                            <tr style="background-color: #f9f9f9;">
                                                <td><strong>Expiry Date</strong></td>
                                                <td style="color: #ff5722; font-weight: bold;">
                                                    {{ object.license_expiry }}
                                                </td>
                                            </tr>
                                            <tr>
                                                <td><strong>Days Remaining</strong></td>
                                                <td style="color: #ff5722; font-weight: bold;">
                                                    {{ object.days_until_expiry }} days
                                                </td>
                                            </tr>
                                        </table>

                                        <p style="color: #d32f2f;">
                                            <strong>Important:</strong> If your license expires, you will be
                                            automatically suspended from all trip assignments until the
                                            license is renewed.
                                        </p>

                                        <p>Please renew your license at the earliest convenience and
                                           update the system with the new expiry date.</p>

                                        <p>Best regards,<br/>
                                        <strong>TransitOps Fleet Management</strong></p>
                                    </td>
                                </tr>
                                <!-- Footer -->
                                <tr>
                                    <td style="background-color: #f5f5f5; padding: 15px; text-align: center;
                                               font-size: 12px; color: #888;">
                                        This is an automated message from TransitOps.
                                        Please do not reply to this email.
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

</odoo>
