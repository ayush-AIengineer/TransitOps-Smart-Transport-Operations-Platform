<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================== -->
    <!-- SCHEDULED ACTION: License Expiry Check                              -->
    <!-- ================================================================== -->
    <record id="ir_cron_license_expiry_check" model="ir.cron">
        <field name="name">TransitOps: Check Driver License Expiry</field>
        <field name="model_id" ref="model_transit_driver"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_license_expiry()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="doall">False</field>
    </record>

</odoo>
