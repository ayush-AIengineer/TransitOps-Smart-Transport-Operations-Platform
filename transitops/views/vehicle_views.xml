<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================== -->
    <!-- VEHICLE FORM VIEW                                                   -->
    <!-- ================================================================== -->
    <record id="view_transit_vehicle_form" model="ir.ui.view">
        <field name="name">transit.vehicle.form</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <header>
                    <button name="action_retire" string="Retire Vehicle"
                            type="object" class="btn-secondary"
                            invisible="status in ('retired', 'on_trip')"
                            groups="transitops.group_transit_manager"
                            confirm="Are you sure you want to retire this vehicle? This action cannot be easily undone."/>
                    <button name="action_reactivate" string="Reactivate"
                            type="object" class="btn-primary"
                            invisible="status != 'retired'"
                            groups="transitops.group_transit_manager"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="available,on_trip,in_shop,retired"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_trips" type="object"
                                class="oe_stat_button" icon="fa-road">
                            <field name="total_trips" widget="statinfo" string="Trips"/>
                        </button>
                        <button name="action_view_maintenance" type="object"
                                class="oe_stat_button" icon="fa-wrench">
                            <span class="o_stat_text">Maintenance</span>
                        </button>
                        <button name="action_view_fuel_logs" type="object"
                                class="oe_stat_button" icon="fa-tint">
                            <span class="o_stat_text">Fuel Logs</span>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Vehicle Name/Model"/>
                        </h1>
                        <h3>
                            <field name="registration_no" placeholder="Registration Number"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Vehicle Details">
                            <field name="vehicle_type"/>
                            <field name="max_capacity"/>
                            <field name="odometer"/>
                            <field name="region"/>
                        </group>
                        <group string="Financial">
                            <field name="acquisition_cost" widget="monetary"/>
                            <field name="total_fuel_cost" widget="monetary"/>
                            <field name="total_maintenance_cost" widget="monetary"/>
                            <field name="total_ops_cost" widget="monetary"/>
                            <field name="fuel_efficiency"/>
                            <field name="vehicle_roi" widget="percentage"/>
                        </group>
                    </group>
                    <group string="Statistics">
                        <group>
                            <field name="total_trips"/>
                            <field name="total_distance"/>
                        </group>
                        <group>
                            <field name="total_expense" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                        <page string="Trips" name="trips">
                            <field name="trip_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="source"/>
                                    <field name="destination"/>
                                    <field name="driver_id"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'completed'"
                                           decoration-info="state == 'dispatched'"
                                           decoration-warning="state == 'draft'"
                                           decoration-danger="state == 'cancelled'"/>
                                    <field name="actual_distance"/>
                                </list>
                            </field>
                        </page>
                        <page string="Maintenance History" name="maintenance">
                            <field name="maintenance_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="maintenance_type"/>
                                    <field name="cost" widget="monetary"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="state" widget="badge"
                                           decoration-warning="state == 'in_progress'"
                                           decoration-success="state == 'done'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Fuel Logs" name="fuel_logs">
                            <field name="fuel_log_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="liters"/>
                                    <field name="cost" widget="monetary"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- VEHICLE LIST VIEW                                                   -->
    <!-- ================================================================== -->
    <record id="view_transit_vehicle_list" model="ir.ui.view">
        <field name="name">transit.vehicle.list</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <list string="Vehicles"
                  decoration-success="status == 'available'"
                  decoration-info="status == 'on_trip'"
                  decoration-warning="status == 'in_shop'"
                  decoration-muted="status == 'retired'">
                <field name="registration_no"/>
                <field name="name"/>
                <field name="vehicle_type"/>
                <field name="max_capacity"/>
                <field name="odometer"/>
                <field name="region"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'available'"
                       decoration-info="status == 'on_trip'"
                       decoration-warning="status == 'in_shop'"
                       decoration-danger="status == 'retired'"/>
                <field name="total_trips"/>
                <field name="fuel_efficiency"/>
                <field name="total_ops_cost" widget="monetary" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- VEHICLE KANBAN VIEW                                                 -->
    <!-- ================================================================== -->
    <record id="view_transit_vehicle_kanban" model="ir.ui.view">
        <field name="name">transit.vehicle.kanban</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="name"/>
                <field name="registration_no"/>
                <field name="vehicle_type"/>
                <field name="status"/>
                <field name="color"/>
                <field name="max_capacity"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top mb8">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="status" widget="label_selection"
                                       options="{'classes': {'available': 'success', 'on_trip': 'info', 'in_shop': 'warning', 'retired': 'danger'}}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><strong>Reg:</strong> <field name="registration_no"/></div>
                                <div><strong>Type:</strong> <field name="vehicle_type"/></div>
                                <div><strong>Capacity:</strong> <field name="max_capacity"/> kg</div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- VEHICLE SEARCH VIEW                                                 -->
    <!-- ================================================================== -->
    <record id="view_transit_vehicle_search" model="ir.ui.view">
        <field name="name">transit.vehicle.search</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <search string="Search Vehicles">
                <field name="name"/>
                <field name="registration_no"/>
                <field name="region"/>
                <separator/>
                <filter string="Available" name="available"
                        domain="[('status', '=', 'available')]"/>
                <filter string="On Trip" name="on_trip"
                        domain="[('status', '=', 'on_trip')]"/>
                <filter string="In Maintenance" name="in_shop"
                        domain="[('status', '=', 'in_shop')]"/>
                <filter string="Retired" name="retired"
                        domain="[('status', '=', 'retired')]"/>
                <separator/>
                <filter string="Trucks" name="trucks"
                        domain="[('vehicle_type', '=', 'truck')]"/>
                <filter string="Vans" name="vans"
                        domain="[('vehicle_type', '=', 'van')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status"
                            context="{'group_by': 'status'}"/>
                    <filter string="Vehicle Type" name="group_type"
                            context="{'group_by': 'vehicle_type'}"/>
                    <filter string="Region" name="group_region"
                            context="{'group_by': 'region'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- VEHICLE GRAPH VIEW                                                  -->
    <!-- ================================================================== -->
    <record id="view_transit_vehicle_graph" model="ir.ui.view">
        <field name="name">transit.vehicle.graph</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <graph string="Vehicle Analytics" type="bar">
                <field name="vehicle_type" type="row"/>
                <field name="total_ops_cost" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- VEHICLE PIVOT VIEW                                                  -->
    <!-- ================================================================== -->
    <record id="view_transit_vehicle_pivot" model="ir.ui.view">
        <field name="name">transit.vehicle.pivot</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <pivot string="Vehicle Analysis">
                <field name="vehicle_type" type="row"/>
                <field name="status" type="col"/>
                <field name="total_ops_cost" type="measure"/>
                <field name="fuel_efficiency" type="measure"/>
                <field name="total_trips" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- VEHICLE ACTION                                                      -->
    <!-- ================================================================== -->
    <record id="action_transit_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">transit.vehicle</field>
        <field name="view_mode">list,kanban,form,graph,pivot</field>
        <field name="search_view_id" ref="view_transit_vehicle_search"/>
        <field name="context">{'search_default_available': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first vehicle!
            </p>
            <p>
                Add vehicles to your fleet to start managing trips and maintenance.
            </p>
        </field>
    </record>

</odoo>
