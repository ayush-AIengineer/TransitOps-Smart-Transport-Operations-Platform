<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================== -->
    <!-- DRIVER FORM VIEW                                                    -->
    <!-- ================================================================== -->
    <record id="view_transit_driver_form" model="ir.ui.view">
        <field name="name">transit.driver.form</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <form string="Driver">
                <header>
                    <button name="action_suspend" string="Suspend"
                            type="object" class="btn-danger"
                            invisible="status in ('suspended', 'on_trip')"
                            groups="transitops.group_transit_manager,transitops.group_transit_safety"/>
                    <button name="action_reinstate" string="Reinstate"
                            type="object" class="btn-success"
                            invisible="status not in ('suspended', 'off_duty')"
                            groups="transitops.group_transit_manager,transitops.group_transit_safety"/>
                    <button name="action_off_duty" string="Set Off Duty"
                            type="object" class="btn-secondary"
                            invisible="status != 'available'"
                            groups="transitops.group_transit_manager,transitops.group_transit_safety"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="available,on_trip,off_duty,suspended"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_trips" type="object"
                                class="oe_stat_button" icon="fa-road">
                            <field name="total_trips" widget="statinfo" string="Trips"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Driver Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="License Information">
                            <field name="license_number"/>
                            <field name="license_category"/>
                            <field name="license_expiry"/>
                            <field name="is_license_expired" invisible="not is_license_expired"/>
                            <field name="is_license_expiring_soon" invisible="not is_license_expiring_soon"/>
                            <field name="days_until_expiry"/>
                        </group>
                        <group string="Contact &amp; Details">
                            <field name="contact_number" widget="phone"/>
                            <field name="email" widget="email"/>
                            <field name="safety_score" widget="progressbar"
                                   options="{'max_value': 100}"/>
                            <field name="date_of_joining"/>
                        </group>
                    </group>
                    <group>
                        <group string="Statistics">
                            <field name="total_trips"/>
                            <field name="total_distance"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Address" name="address">
                            <field name="address" placeholder="Driver address..."/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                        <page string="Trip History" name="trips">
                            <field name="trip_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="source"/>
                                    <field name="destination"/>
                                    <field name="vehicle_id"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'completed'"
                                           decoration-info="state == 'dispatched'"
                                           decoration-warning="state == 'draft'"
                                           decoration-danger="state == 'cancelled'"/>
                                    <field name="actual_distance"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- DRIVER LIST VIEW                                                    -->
    <!-- ================================================================== -->
    <record id="view_transit_driver_list" model="ir.ui.view">
        <field name="name">transit.driver.list</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <list string="Drivers"
                  decoration-success="status == 'available'"
                  decoration-info="status == 'on_trip'"
                  decoration-warning="status == 'off_duty'"
                  decoration-danger="status == 'suspended' or is_license_expired == True">
                <field name="name"/>
                <field name="license_number"/>
                <field name="license_category"/>
                <field name="license_expiry"/>
                <field name="contact_number"/>
                <field name="safety_score" widget="progressbar"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'available'"
                       decoration-info="status == 'on_trip'"
                       decoration-warning="status == 'off_duty'"
                       decoration-danger="status == 'suspended'"/>
                <field name="is_license_expired" column_invisible="1"/>
                <field name="total_trips"/>
                <field name="days_until_expiry" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- DRIVER KANBAN VIEW                                                  -->
    <!-- ================================================================== -->
    <record id="view_transit_driver_kanban" model="ir.ui.view">
        <field name="name">transit.driver.kanban</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="name"/>
                <field name="license_number"/>
                <field name="status"/>
                <field name="safety_score"/>
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top mb8">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="status" widget="label_selection"
                                       options="{'classes': {'available': 'success', 'on_trip': 'info', 'off_duty': 'warning', 'suspended': 'danger'}}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><strong>License:</strong> <field name="license_number"/></div>
                                <div><strong>Safety:</strong> <field name="safety_score"/>%</div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- DRIVER SEARCH VIEW                                                  -->
    <!-- ================================================================== -->
    <record id="view_transit_driver_search" model="ir.ui.view">
        <field name="name">transit.driver.search</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <search string="Search Drivers">
                <field name="name"/>
                <field name="license_number"/>
                <field name="contact_number"/>
                <separator/>
                <filter string="Available" name="available"
                        domain="[('status', '=', 'available')]"/>
                <filter string="On Trip" name="on_trip"
                        domain="[('status', '=', 'on_trip')]"/>
                <filter string="Off Duty" name="off_duty"
                        domain="[('status', '=', 'off_duty')]"/>
                <filter string="Suspended" name="suspended"
                        domain="[('status', '=', 'suspended')]"/>
                <separator/>
                <filter string="License Expired" name="license_expired"
                        domain="[('is_license_expired', '=', True)]"/>
                <filter string="License Expiring Soon" name="license_expiring"
                        domain="[('is_license_expiring_soon', '=', True)]"/>
                <filter string="Low Safety Score (&lt;50)" name="low_safety"
                        domain="[('safety_score', '&lt;', 50)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status"
                            context="{'group_by': 'status'}"/>
                    <filter string="License Category" name="group_license"
                            context="{'group_by': 'license_category'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- DRIVER ACTION                                                       -->
    <!-- ================================================================== -->
    <record id="action_transit_driver" model="ir.actions.act_window">
        <field name="name">Drivers</field>
        <field name="res_model">transit.driver</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_transit_driver_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first driver!
            </p>
            <p>
                Add drivers with their license details to start assigning trips.
            </p>
        </field>
    </record>

</odoo>
