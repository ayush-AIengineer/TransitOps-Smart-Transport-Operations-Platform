<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================== -->
    <!-- DASHBOARD FORM VIEW (Single Record)                                 -->
    <!-- ================================================================== -->
    <record id="view_transit_dashboard_form" model="ir.ui.view">
        <field name="name">transit.dashboard.form</field>
        <field name="model">transit.dashboard</field>
        <field name="arch" type="xml">
            <form string="TransitOps Dashboard" create="0" edit="0" delete="0">
                <sheet>
                    <div class="container-fluid o_transitops_dashboard">
                        <!-- Header -->
                        <div class="row mb-4">
                            <div class="col-12 text-center">
                                <h1 class="text-primary">
                                    <i class="fa fa-dashboard"/> TransitOps Dashboard
                                </h1>
                                <p class="text-muted">Real-time fleet operations overview</p>
                            </div>
                        </div>

                        <!-- Vehicle KPIs Row -->
                        <div class="row mb-3">
                            <div class="col-12">
                                <h3><i class="fa fa-truck"/> Vehicle Overview</h3>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-3 col-sm-6 mb-2">
                                <div class="card bg-primary text-white text-center p-3">
                                    <h4><field name="total_vehicles"/></h4>
                                    <small>Total Vehicles</small>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-2">
                                <div class="card bg-success text-white text-center p-3">
                                    <h4><field name="available_vehicles"/></h4>
                                    <small>Available</small>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-2">
                                <div class="card bg-info text-white text-center p-3">
                                    <h4><field name="active_vehicles"/></h4>
                                    <small>On Trip</small>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-2">
                                <div class="card bg-warning text-white text-center p-3">
                                    <h4><field name="in_maintenance"/></h4>
                                    <small>In Maintenance</small>
                                </div>
                            </div>
                        </div>

                        <!-- Trip KPIs Row -->
                        <div class="row mb-3">
                            <div class="col-12">
                                <h3><i class="fa fa-road"/> Trip Overview</h3>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-4 col-sm-6 mb-2">
                                <div class="card bg-info text-white text-center p-3">
                                    <h4><field name="active_trips"/></h4>
                                    <small>Active Trips</small>
                                </div>
                            </div>
                            <div class="col-md-4 col-sm-6 mb-2">
                                <div class="card bg-warning text-white text-center p-3">
                                    <h4><field name="pending_trips"/></h4>
                                    <small>Pending Trips</small>
                                </div>
                            </div>
                            <div class="col-md-4 col-sm-6 mb-2">
                                <div class="card bg-success text-white text-center p-3">
                                    <h4><field name="completed_trips"/></h4>
                                    <small>Completed Trips</small>
                                </div>
                            </div>
                        </div>

                        <!-- Driver KPIs Row -->
                        <div class="row mb-3">
                            <div class="col-12">
                                <h3><i class="fa fa-id-card"/> Driver Overview</h3>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-3 col-sm-6 mb-2">
                                <div class="card bg-primary text-white text-center p-3">
                                    <h4><field name="total_drivers"/></h4>
                                    <small>Total Drivers</small>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-2">
                                <div class="card bg-info text-white text-center p-3">
                                    <h4><field name="drivers_on_duty"/></h4>
                                    <small>On Duty</small>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-2">
                                <div class="card bg-success text-white text-center p-3">
                                    <h4><field name="available_drivers"/></h4>
                                    <small>Available</small>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-2">
                                <div class="card bg-danger text-white text-center p-3">
                                    <h4><field name="suspended_drivers"/></h4>
                                    <small>Suspended</small>
                                </div>
                            </div>
                        </div>

                        <!-- Fleet Metrics Row -->
                        <div class="row mb-3">
                            <div class="col-12">
                                <h3><i class="fa fa-line-chart"/> Fleet Metrics</h3>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-4 col-sm-6 mb-2">
                                <div class="card bg-primary text-white text-center p-3">
                                    <h4><field name="fleet_utilization"/>%</h4>
                                    <small>Fleet Utilization</small>
                                </div>
                            </div>
                            <div class="col-md-4 col-sm-6 mb-2">
                                <div class="card bg-success text-white text-center p-3">
                                    <h4><field name="avg_fuel_efficiency"/> km/L</h4>
                                    <small>Avg Fuel Efficiency</small>
                                </div>
                            </div>
                            <div class="col-md-4 col-sm-6 mb-2">
                                <div class="card bg-danger text-white text-center p-3">
                                    <h4><field name="total_ops_cost" widget="monetary"/></h4>
                                    <small>Total Ops Cost</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- DASHBOARD ACTION                                                    -->
    <!-- ================================================================== -->
    <record id="action_transit_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">transit.dashboard</field>
        <field name="view_mode">form</field>
        <field name="res_id">1</field>
        <field name="target">inline</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Welcome to TransitOps Dashboard!
            </p>
        </field>
    </record>

</odoo>
